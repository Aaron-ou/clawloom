# WorldSeed Engine Environment Variables

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clawloom

# OpenClaw API
OPENCLAW_URL=http://localhost:8080
OPENCLAW_API_KEY=your_api_key_here

# Engine Settings
DEFAULT_TICKS_PER_BATCH=10
MAX_TICKS_PER_BATCH=100
TICK_DELAY_SECONDS=0.1

# Logging
LOG_LEVEL=INFO
